{
  "name": "tongxie-shop-api",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "wrangler dev --port 8787",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute tongxie-shop-db --local --file=../schema.sql",
    "db:seed": "wrangler d1 execute tongxie-shop-db --local --file=../seed.sql",
    "db:reset": "rm -f .wrangler/state/d1/*.sqlite && npm run db:init && npm run db:seed"
  },
  "devDependencies": {
    "wrangler": "^4.93.0"
  }
}
